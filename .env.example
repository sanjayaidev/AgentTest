# Create an integration at https://www.canva.com/developers/integrations
# then fill these in from its "Configuration" page.

CANVA_CLIENT_ID=your_integration_client_id
CANVA_CLIENT_SECRET=your_integration_client_secret

# Must be set EXACTLY (scheme, host, path, trailing slash) as one of the
# "Authentication redirect URIs" you configure for the integration.
CANVA_REDIRECT_URI=http://localhost:3000/auth/canva/callback

# Space-separated. Must be a subset of the scopes you enabled for the
# integration in the Developer Portal — requesting a scope here that
# isn't enabled there will fail at the authorize step.
CANVA_SCOPES=design:content:read design:content:write asset:read asset:write

PORT=3000

# Session cookie signing secret — any random string, generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_random_string
